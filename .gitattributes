# Normalize line endings: LF in the repo, checked out native on each OS.
* text=auto eol=lf

# Windows-specific scripts stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.ttf binary
*.otf binary
*.keystore binary
*.jks binary
